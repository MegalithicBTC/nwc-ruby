#!/usr/bin/env ruby
# frozen_string_literal: true

# Quick diagnostic for an NWC connection string.
#
# Usage:
#   bin/nwc_test                     # test (read tests + write if applicable)
#   bin/nwc_test notifications       # listen for notifications (blocks forever)
#
# Environment variables:
#   NWC_URL                    (required) nostr+walletconnect://...
#   PAY_TO_LIGHTNING_ADDRESS   (optional) Lightning address for write test
#   PAY_TO_SATOSHIS_AMOUNT     (optional, default 100) sats for write test

require 'bundler/setup'
require 'nwc_ruby'

nwc_url = ENV.fetch('NWC_URL') do
  abort "ERROR: NWC_URL env var is required.\n  " \
        "NWC_URL=\"nostr+walletconnect://...\" #{$PROGRAM_NAME}"
end

case ARGV[0]
when 'notifications'
  NwcRuby.test_notifications(nwc_url: nwc_url)
  exit 0
else
  ok = NwcRuby.test(
    nwc_url: nwc_url,
    pay_to_lightning_address: ENV.fetch('PAY_TO_LIGHTNING_ADDRESS', nil),
    pay_to_satoshis_amount: Integer(ENV.fetch('PAY_TO_SATOSHIS_AMOUNT', 100))
  )
  exit(ok ? 0 : 1)
end
